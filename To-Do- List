<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>TaskOps</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #080b12;
  --surf: #0f1420;
  --surf2: #161d2e;
  --surf3: #1e2740;
  --border: #2a3550;
  --border2: #3a4a65;
  --text: #dde4f0;
  --text2: #8899b0;
  --text3: #4a5a75;
  --accent: #f0a030;
  --p-low: #3dd68c;
  --p-low-bg: #0a2018;
  --p-low-border: #1a5030;
  --p-med: #4d9ffc;
  --p-med-bg: #08182e;
  --p-med-border: #1a3560;
  --p-high: #ff7c3a;
  --p-high-bg: #280e00;
  --p-high-border: #582010;
  --p-urgent: #ff3a5c;
  --p-urgent-bg: #220008;
  --p-urgent-border: #580018;
  --s-reschedule: #f0b429;
  --s-cancel: #6b7a90;
  --nav-h: 62px;
  --header-h: 54px;
}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
html,body{height:100%;overflow:hidden}
body{font-family:'Outfit',sans-serif;background:var(--bg);color:var(--text);max-width:430px;margin:0 auto;display:flex;flex-direction:column}

/* ── HEADER ── */
.app-header{height:var(--header-h);background:var(--surf);border-bottom:1px solid var(--border);display:flex;align-items:center;padding:0 16px;flex-shrink:0;gap:10px}
.app-logo{font-family:'Space Mono',monospace;font-size:17px;font-weight:700;color:var(--accent);letter-spacing:-0.5px}
.app-logo span{color:var(--text2);font-weight:400}
.header-right{margin-left:auto;display:flex;align-items:center;gap:8px}
.unseen-pill{background:var(--p-urgent);color:#fff;font-size:9px;font-weight:700;padding:3px 8px;border-radius:10px;font-family:'Space Mono',monospace;display:none;animation:pulse-badge 1.5s infinite}
@keyframes pulse-badge{0%,100%{opacity:1}50%{opacity:.7}}

/* ── TABS ── */
.tab-content{flex:1;overflow:hidden;position:relative}
.tab-pane{position:absolute;inset:0;overflow-y:auto;padding-bottom:calc(var(--nav-h)+16px);display:none;scrollbar-width:thin;scrollbar-color:var(--border) transparent}
.tab-pane::-webkit-scrollbar{width:3px}
.tab-pane::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px}
.tab-pane.active{display:block}

/* ── BOTTOM NAV ── */
.bottom-nav{height:var(--nav-h);background:var(--surf);border-top:1px solid var(--border);display:flex;flex-shrink:0}
.nav-btn{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:3px;background:none;border:none;color:var(--text3);cursor:pointer;transition:color .2s;position:relative;font-family:'Outfit',sans-serif}
.nav-btn.active{color:var(--accent)}
.nav-icon{font-size:19px}
.nav-label{font-size:9px;font-weight:700;letter-spacing:.8px;text-transform:uppercase}
.nav-dot{position:absolute;top:9px;right:calc(50% - 12px);width:6px;height:6px;border-radius:50%;background:var(--p-urgent);display:none}

/* ── FAB ── */
.fab{position:fixed;bottom:calc(var(--nav-h)+14px);right:max(16px, calc((100vw - 430px)/2 + 16px));width:50px;height:50px;background:var(--accent);border-radius:50%;border:none;color:#080b12;font-size:26px;font-weight:300;cursor:pointer;box-shadow:0 4px 20px rgba(240,160,48,.4);display:flex;align-items:center;justify-content:center;transition:transform .2s,box-shadow .2s;z-index:100}
.fab:active{transform:scale(.92);box-shadow:0 2px 10px rgba(240,160,48,.3)}

/* ── COMMON ── */
.section-pad{padding:16px}
.card-block{background:var(--surf2);border:1px solid var(--border);border-radius:16px;padding:16px;margin-bottom:14px}
.card-title{font-size:11px;font-weight:700;color:var(--text2);text-transform:uppercase;letter-spacing:1px;margin-bottom:12px}
.section-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px}
.section-title{font-size:11px;font-weight:700;color:var(--text2);text-transform:uppercase;letter-spacing:1px}
.view-all-btn{font-size:11px;color:var(--accent);background:none;border:none;cursor:pointer;font-family:'Outfit',sans-serif;font-weight:600}
.empty-state{text-align:center;padding:36px 20px;color:var(--text3)}
.empty-icon{font-size:36px;margin-bottom:8px}
.empty-text{font-size:13px;font-weight:500}

/* ── HOME: STATS ── */
.stats-row{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:14px}
.stat-card{background:var(--surf2);border:1px solid var(--border);border-radius:12px;padding:12px 8px;text-align:center}
.stat-num{font-family:'Space Mono',monospace;font-size:26px;font-weight:700;line-height:1}
.stat-label{font-size:9px;color:var(--text2);margin-top:4px;font-weight:600;text-transform:uppercase;letter-spacing:.5px}
.stat-card.s-total .stat-num{color:var(--accent)}
.stat-card.s-pending .stat-num{color:var(--p-high)}
.stat-card.s-done .stat-num{color:var(--p-low)}

/* ── HOME: CHART ── */
.chart-wrap{display:flex;align-items:center;gap:16px}
.chart-legend{flex:1}
.legend-item{display:flex;align-items:center;gap:8px;margin-bottom:8px}
.legend-dot{width:9px;height:9px;border-radius:50%;flex-shrink:0}
.legend-label{font-size:10px;color:var(--text2);font-weight:500}
.legend-val{font-family:'Space Mono',monospace;font-size:13px;font-weight:700;color:var(--text)}

/* ── HOME: PRODUCTIVITY ── */
.prod-row{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:12px}
.prod-item{background:var(--surf3);border-radius:10px;padding:11px}
.prod-item-label{font-size:9px;color:var(--text2);text-transform:uppercase;letter-spacing:.5px;font-weight:600;margin-bottom:3px}
.prod-item-val{font-family:'Space Mono',monospace;font-size:20px;font-weight:700;color:var(--accent)}
.prod-item-sub{font-size:10px;color:var(--text3);margin-top:2px}
.progress-bar-label{display:flex;justify-content:space-between;font-size:11px;color:var(--text2);margin-bottom:5px}
.progress-bar{height:6px;background:var(--surf3);border-radius:3px;overflow:hidden}
.progress-fill{height:100%;border-radius:3px;background:linear-gradient(90deg,var(--p-low),var(--accent));transition:width .6s ease}

/* ── ALARM CARD ── */
.alarm-card{background:rgba(255,58,92,.08);border:1px solid rgba(255,58,92,.3);border-radius:11px;padding:11px;margin-bottom:10px;display:flex;align-items:center;gap:10px}
.alarm-icon{font-size:18px;flex-shrink:0}
.alarm-text{flex:1;font-size:12px;color:var(--p-urgent);font-weight:600;line-height:1.3}
.alarm-close{background:none;border:none;color:var(--text3);cursor:pointer;font-size:18px;line-height:1;padding:0 4px}

/* ── TASK CARD ── */
.task-card{background:var(--surf2);border:1px solid var(--border);border-radius:14px;padding:13px 13px 13px 17px;margin-bottom:9px;cursor:pointer;position:relative;overflow:hidden;animation:slide-in .2s ease}
@keyframes slide-in{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}
.task-card::before{content:'';position:absolute;left:0;top:0;bottom:0;width:4px;border-radius:4px 0 0 4px}
.task-card[data-p="low"]::before{background:var(--p-low)}
.task-card[data-p="medium"]::before{background:var(--p-med)}
.task-card[data-p="high"]::before{background:var(--p-high)}
.task-card[data-p="urgent"]::before{background:var(--p-urgent)}
.task-card.is-rescheduled{border-color:var(--s-reschedule);background:linear-gradient(135deg,var(--surf2),rgba(240,180,41,.04))}
.task-card.is-cancelled{border-color:var(--border);opacity:.6}
.task-card.is-cancelled .tc-name{text-decoration:line-through;color:var(--text3)}
.task-card.is-completed{border-color:rgba(61,214,140,.25);background:linear-gradient(135deg,var(--surf2),rgba(61,214,140,.03))}
.task-card.is-urgent{border-color:var(--p-urgent);animation:slide-in .2s ease,urgent-glow 2s infinite}
@keyframes urgent-glow{0%,100%{box-shadow:0 0 0 0 rgba(255,58,92,0)}50%{box-shadow:0 0 0 3px rgba(255,58,92,.18)}}
.tc-header{display:flex;align-items:flex-start;gap:8px;margin-bottom:7px}
.tc-priority{font-size:8px;font-weight:700;text-transform:uppercase;letter-spacing:.8px;padding:3px 7px;border-radius:5px;flex-shrink:0;font-family:'Space Mono',monospace;margin-top:1px}
.p-low{background:var(--p-low-bg);color:var(--p-low);border:1px solid var(--p-low-border)}
.p-medium{background:var(--p-med-bg);color:var(--p-med);border:1px solid var(--p-med-border)}
.p-high{background:var(--p-high-bg);color:var(--p-high);border:1px solid var(--p-high-border)}
.p-urgent{background:var(--p-urgent-bg);color:var(--p-urgent);border:1px solid var(--p-urgent-border)}
.tc-name{font-size:13px;font-weight:600;color:var(--text);flex:1;line-height:1.35}
.tc-badges{display:flex;gap:5px;flex-wrap:wrap;margin-bottom:7px}
.tc-badge{font-size:9px;padding:2px 7px;border-radius:5px;font-weight:600}
.b-store{background:rgba(77,159,252,.1);color:var(--p-med);border:1px solid rgba(77,159,252,.2)}
.b-type{background:rgba(240,160,48,.1);color:var(--accent);border:1px solid rgba(240,160,48,.2)}
.b-unseen{background:rgba(255,58,92,.12);color:var(--p-urgent);border:1px solid rgba(255,58,92,.25)}
.b-seen{background:rgba(61,214,140,.08);color:var(--p-low);border:1px solid rgba(61,214,140,.18)}
.b-resch{background:rgba(240,180,41,.1);color:var(--s-reschedule);border:1px solid rgba(240,180,41,.2)}
.b-cancelled{background:rgba(107,122,144,.1);color:var(--text2);border:1px solid rgba(107,122,144,.2)}
.b-done{background:rgba(61,214,140,.1);color:var(--p-low);border:1px solid rgba(61,214,140,.2)}
.tc-deadline{font-size:11px;color:var(--text2);margin-bottom:4px}
.tc-deadline.overdue{color:var(--p-urgent)}
.tc-deadline.due-soon{color:var(--p-high)}
.tc-tat{font-size:10px;color:var(--text3);font-family:'Space Mono',monospace}
.tc-actions{display:flex;gap:6px;margin-top:9px;padding-top:9px;border-top:1px solid var(--border)}
.ta-btn{flex:1;padding:7px 4px;border-radius:8px;border:1px solid;font-size:11px;font-weight:700;cursor:pointer;font-family:'Outfit',sans-serif;text-align:center;transition:opacity .15s}
.ta-btn:active{opacity:.7}
.ta-complete{background:rgba(61,214,140,.1);color:var(--p-low);border-color:rgba(61,214,140,.3)}
.ta-reschedule{background:rgba(240,180,41,.1);color:var(--s-reschedule);border-color:rgba(240,180,41,.3)}
.ta-cancel{background:rgba(107,122,144,.08);color:var(--text2);border-color:rgba(107,122,144,.2)}
.ta-reopen{background:rgba(77,159,252,.1);color:var(--p-med);border-color:rgba(77,159,252,.25);flex:2}

/* ── FORM ── */
.form-wrap{padding:16px}
.form-head{margin-bottom:18px}
.form-head h2{font-size:20px;font-weight:800}
.form-head p{font-size:12px;color:var(--text2);margin-top:4px}
.form-group{margin-bottom:15px}
.form-label{display:block;font-size:10px;font-weight:700;color:var(--text2);text-transform:uppercase;letter-spacing:.8px;margin-bottom:7px}
.form-label em{color:var(--p-urgent);font-style:normal}
.form-ctrl{width:100%;background:var(--surf2);border:1px solid var(--border);border-radius:10px;padding:11px 13px;color:var(--text);font-family:'Outfit',sans-serif;font-size:14px;transition:border-color .2s;appearance:none;-webkit-appearance:none;outline:none}
.form-ctrl:focus{border-color:var(--accent)}
.form-ctrl option{background:var(--surf2)}
textarea.form-ctrl{resize:none;height:96px;line-height:1.5}
input[type="datetime-local"]{color-scheme:dark}
.char-count{text-align:right;font-size:10px;color:var(--text3);margin-top:3px;font-family:'Space Mono',monospace}

.priority-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px}
.p-option{padding:10px 8px;border-radius:10px;border:2px solid var(--border);background:var(--surf2);cursor:pointer;transition:all .2s;text-align:center}
.p-option .pi{font-size:16px;margin-bottom:3px}
.p-option .pl{font-size:11px;font-weight:700;font-family:'Space Mono',monospace;color:var(--text3)}
.p-option[data-v="low"].sel{border-color:var(--p-low);background:var(--p-low-bg)}
.p-option[data-v="low"].sel .pl{color:var(--p-low)}
.p-option[data-v="medium"].sel{border-color:var(--p-med);background:var(--p-med-bg)}
.p-option[data-v="medium"].sel .pl{color:var(--p-med)}
.p-option[data-v="high"].sel{border-color:var(--p-high);background:var(--p-high-bg)}
.p-option[data-v="high"].sel .pl{color:var(--p-high)}
.p-option[data-v="urgent"].sel{border-color:var(--p-urgent);background:var(--p-urgent-bg)}
.p-option[data-v="urgent"].sel .pl{color:var(--p-urgent)}

.toggle-row{display:flex;align-items:center;justify-content:space-between;background:var(--surf2);border:1px solid var(--border);border-radius:10px;padding:11px 13px}
.toggle-info .toggle-title{font-size:14px;font-weight:600}
.toggle-info .toggle-sub{font-size:11px;color:var(--text2);margin-top:2px}
.toggle-sw{position:relative;width:44px;height:24px;flex-shrink:0}
.toggle-sw input{opacity:0;width:0;height:0;position:absolute}
.toggle-track{position:absolute;inset:0;background:var(--surf3);border-radius:12px;cursor:pointer;transition:background .2s}
.toggle-track::before{content:'';position:absolute;width:18px;height:18px;left:3px;top:3px;background:white;border-radius:50%;transition:transform .2s}
.toggle-sw input:checked+.toggle-track{background:var(--accent)}
.toggle-sw input:checked+.toggle-track::before{transform:translateX(20px)}

.btn-submit{width:100%;background:var(--accent);color:#080b12;border:none;border-radius:12px;padding:13px;font-family:'Outfit',sans-serif;font-size:15px;font-weight:800;cursor:pointer;letter-spacing:.3px;transition:opacity .2s,transform .1s}
.btn-submit:active{opacity:.85;transform:scale(.99)}

/* ── TASKS TAB ── */
.tasks-wrap{padding:16px}
.tasks-head{margin-bottom:13px}
.tasks-head h2{font-size:20px;font-weight:800}
.filter-row{display:flex;gap:6px;overflow-x:auto;padding-bottom:10px;margin-bottom:12px;scrollbar-width:none}
.filter-row::-webkit-scrollbar{display:none}
.filter-btn{flex-shrink:0;padding:7px 14px;border-radius:18px;border:1px solid var(--border);background:var(--surf2);color:var(--text2);font-size:11px;font-weight:700;cursor:pointer;font-family:'Outfit',sans-serif;transition:all .2s}
.filter-btn.active{background:var(--accent);border-color:var(--accent);color:#080b12}
.priority-group{margin-bottom:18px}
.pg-header{display:flex;align-items:center;gap:8px;margin-bottom:10px;padding-bottom:8px;border-bottom:1px solid var(--border)}
.pg-dot{width:8px;height:8px;border-radius:50%}
.pg-label{font-size:11px;font-weight:800;letter-spacing:.5px}
.pg-count{margin-left:auto;font-size:9px;background:var(--surf3);padding:2px 8px;border-radius:10px;color:var(--text2);font-family:'Space Mono',monospace}

/* ── MODALS ── */
.modal-overlay{position:fixed;inset:0;background:rgba(8,11,18,.85);z-index:200;display:flex;align-items:flex-end;justify-content:center;opacity:0;pointer-events:none;transition:opacity .2s;max-width:430px;left:50%;transform:translateX(-50%)}
.modal-overlay.open{opacity:1;pointer-events:all}
.modal-sheet{background:var(--surf);border-radius:20px 20px 0 0;padding:16px 16px 32px;width:100%;border-top:1px solid var(--border);transform:translateY(40px);transition:transform .3s ease;max-height:82vh;overflow-y:auto}
.modal-overlay.open .modal-sheet{transform:translateY(0)}
.modal-handle{width:36px;height:4px;background:var(--border2);border-radius:2px;margin:0 auto 14px}
.modal-title{font-size:16px;font-weight:800;margin-bottom:14px}
.modal-btns{display:flex;gap:10px;margin-top:14px}
.mb-cancel{flex:1;padding:12px;border-radius:10px;background:var(--surf3);border:1px solid var(--border);color:var(--text2);font-family:'Outfit',sans-serif;font-size:14px;font-weight:600;cursor:pointer}
.mb-confirm{flex:2;padding:12px;border-radius:10px;background:var(--accent);border:none;color:#080b12;font-family:'Outfit',sans-serif;font-size:14px;font-weight:800;cursor:pointer}
.mb-danger{flex:2;padding:12px;border-radius:10px;background:rgba(255,58,92,.1);border:1px solid rgba(255,58,92,.3);color:var(--p-urgent);font-family:'Outfit',sans-serif;font-size:14px;font-weight:800;cursor:pointer}

/* detail modal grid */
.detail-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:10px}
.detail-cell{background:var(--surf3);border-radius:8px;padding:9px}
.detail-cell-label{font-size:9px;color:var(--text2);margin-bottom:3px;text-transform:uppercase;letter-spacing:.5px;font-weight:600}
.detail-cell-val{font-size:12px;font-weight:600}
.resch-history{background:var(--surf3);border-radius:8px;padding:9px;margin-top:10px}
.rh-item{font-size:11px;color:var(--text2);padding:5px 0;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;gap:8px}
.rh-item:last-child{border-bottom:none}

/* ── TOAST ── */
.toast{position:fixed;bottom:calc(var(--nav-h)+14px);left:50%;transform:translateX(-50%) translateY(70px);background:var(--surf3);border:1px solid var(--border2);border-radius:10px;padding:9px 18px;font-size:12px;font-weight:600;color:var(--text);z-index:400;transition:transform .25s ease;white-space:nowrap;box-shadow:0 4px 18px rgba(0,0,0,.5)}
.toast.show{transform:translateX(-50%) translateY(0)}
</style>
</head>
<body>

<!-- ── HEADER ── -->
<header class="app-header">
  <div class="app-logo">Task<span>Ops</span></div>
  <div class="header-right">
    <span id="unseenPill" class="unseen-pill">0 NEW</span>
  </div>
</header>

<!-- ── TAB CONTENT ── -->
<div class="tab-content">

  <!-- HOME TAB -->
  <div class="tab-pane active" id="tab-home">
    <div class="section-pad">
      <div id="alarmArea"></div>

      <!-- Stats -->
      <div class="stats-row">
        <div class="stat-card s-total"><div class="stat-num" id="sTotal">0</div><div class="stat-label">Total</div></div>
        <div class="stat-card s-pending"><div class="stat-num" id="sPending">0</div><div class="stat-label">Pending</div></div>
        <div class="stat-card s-done"><div class="stat-num" id="sDone">0</div><div class="stat-label">Done</div></div>
      </div>

      <!-- Chart -->
      <div class="card-block">
        <div class="card-title">📊 Task Overview</div>
        <div class="chart-wrap">
          <canvas id="pieChart" width="100" height="100" style="flex-shrink:0"></canvas>
          <div class="chart-legend">
            <div class="legend-item">
              <div class="legend-dot" style="background:#3dd68c"></div>
              <div><div class="legend-label">Completed</div><div class="legend-val" id="lCompleted">0 (0%)</div></div>
            </div>
            <div class="legend-item">
              <div class="legend-dot" style="background:#ff7c3a"></div>
              <div><div class="legend-label">Pending</div><div class="legend-val" id="lPending">0 (0%)</div></div>
            </div>
            <div class="legend-item">
              <div class="legend-dot" style="background:#6b7a90"></div>
              <div><div class="legend-label">Cancelled</div><div class="legend-val" id="lCancelled">0 (0%)</div></div>
            </div>
          </div>
        </div>
      </div>

      <!-- Productivity -->
      <div class="card-block">
        <div class="card-title">⚡ Productivity</div>
        <div class="prod-row">
          <div class="prod-item">
            <div class="prod-item-label">Lately Done</div>
            <div class="prod-item-val" id="prodLately">0</div>
            <div class="prod-item-sub">Last 7 days</div>
          </div>
          <div class="prod-item">
            <div class="prod-item-label">Avg TAT</div>
            <div class="prod-item-val" id="prodTAT">—</div>
            <div class="prod-item-sub">Days to finish</div>
          </div>
        </div>
        <div class="progress-bar-label"><span>Overall Progress</span><span id="prodPct">0%</span></div>
        <div class="progress-bar"><div class="progress-fill" id="prodBar" style="width:0%"></div></div>
      </div>

      <!-- Ongoing -->
      <div>
        <div class="section-header">
          <div class="section-title">🔄 Ongoing Tasks</div>
          <button class="view-all-btn" onclick="switchTab('tasks')">View All →</button>
        </div>
        <div id="homeOngoing"></div>
      </div>
    </div>
  </div>

  <!-- NEW TASK TAB -->
  <div class="tab-pane" id="tab-new-task">
    <div class="form-wrap">
      <div class="form-head">
        <h2>New Task</h2>
        <p>Add a task with deadline &amp; priority</p>
      </div>

      <!-- Priority -->
      <div class="form-group">
        <label class="form-label">Priority <em>*</em></label>
        <div class="priority-grid">
          <div class="p-option" data-v="low" onclick="selPriority('low')"><div class="pi">🟢</div><div class="pl">Low</div></div>
          <div class="p-option sel" data-v="medium" onclick="selPriority('medium')"><div class="pi">🔵</div><div class="pl">Medium</div></div>
          <div class="p-option" data-v="high" onclick="selPriority('high')"><div class="pi">🟠</div><div class="pl">High</div></div>
          <div class="p-option" data-v="urgent" onclick="selPriority('urgent')"><div class="pi">🔴</div><div class="pl">Urgent!</div></div>
        </div>
      </div>

      <!-- Type -->
      <div class="form-group">
        <label class="form-label">Type <em>*</em></label>
        <select class="form-ctrl" id="fType">
          <option value="high_command">🎯 High Command</option>
          <option value="self" selected>👤 Self</option>
        </select>
      </div>

      <!-- Store -->
      <div class="form-group">
        <label class="form-label">Store Name <em>*</em></label>
        <select class="form-ctrl" id="fStore">
          <option value="all">🏪 All Stores</option>
          <option value="kattur">📍 Kattur</option>
          <option value="cumbum">📍 Cumbum</option>
          <option value="mgt">📍 MGT</option>
          <option value="theni">📍 Theni</option>
          <option value="dindigul">📍 Dindigul</option>
        </select>
      </div>

      <!-- Task Name -->
      <div class="form-group">
        <label class="form-label">Task Name <em>*</em></label>
        <textarea class="form-ctrl" id="fName" placeholder="Describe the task clearly…" maxlength="200" oninput="updateCC()"></textarea>
        <div class="char-count"><span id="ccVal">0</span>/200</div>
      </div>

      <!-- Deadline -->
      <div class="form-group">
        <label class="form-label">Deadline <em>*</em></label>
        <input type="datetime-local" class="form-ctrl" id="fDeadline">
      </div>

      <!-- Alarm -->
      <div class="form-group">
        <div class="toggle-row">
          <div class="toggle-info">
            <div class="toggle-title">⏰ Alarm Reminder</div>
            <div class="toggle-sub">Alert 1 hour before deadline</div>
          </div>
          <label class="toggle-sw">
            <input type="checkbox" id="fAlarm" checked>
            <span class="toggle-track"></span>
          </label>
        </div>
      </div>

      <button class="btn-submit" onclick="createTask()">＋ Create Task</button>
    </div>
  </div>

  <!-- TASKS TAB -->
  <div class="tab-pane" id="tab-tasks">
    <div class="tasks-wrap">
      <div class="tasks-head"><h2>All Tasks</h2></div>
      <div class="filter-row">
        <button class="filter-btn active" onclick="setFilter('all',this)">All</button>
        <button class="filter-btn" onclick="setFilter('pending',this)">Pending</button>
        <button class="filter-btn" onclick="setFilter('completed',this)">Completed</button>
        <button class="filter-btn" onclick="setFilter('cancelled',this)">Cancelled</button>
        <button class="filter-btn" onclick="setFilter('rescheduled',this)">↺ Rescheduled</button>
        <button class="filter-btn" onclick="setFilter('urgent',this)">🔴 Urgent</button>
      </div>
      <div id="tasksList"></div>
    </div>
  </div>
</div>

<!-- ── BOTTOM NAV ── -->
