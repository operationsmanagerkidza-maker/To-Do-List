    <div class="modal-handle"></div>
    <div id="detailContent"></div>
    <div class="modal-btns" style="margin-top:10px">
      <button class="mb-cancel" style="flex:1" onclick="closeModal('mDetail')">Close</button>
    </div>
  </div>
</div>

<!-- Toast -->
<div class="toast" id="toast"></div>

<script>
// ───────────────────── DATA ─────────────────────
let tasks = JSON.parse(localStorage.getItem('taskops') || '[]');
let selP = 'medium';
let activeId = null;
let curFilter = 'all';

function save() { localStorage.setItem('taskops', JSON.stringify(tasks)); }
function genId() { return Date.now().toString(36) + Math.random().toString(36).substr(2,5); }

// ───────────────────── TAB NAV ─────────────────────
function switchTab(tab) {
  document.querySelectorAll('.tab-pane').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('tab-' + tab).classList.add('active');
  document.getElementById('nav-' + tab).classList.add('active');
  document.getElementById('fab').style.display = tab === 'new-task' ? 'none' : 'flex';
  if (tab === 'home') renderHome();
  if (tab === 'tasks') { markAllSeen(); renderTasks(); }
  if (tab === 'new-task') resetForm();
}

// ───────────────────── FORM ─────────────────────
function selPriority(p) {
  selP = p;
  document.querySelectorAll('.p-option').forEach(el =>
    el.classList.toggle('sel', el.dataset.v === p));
}
function updateCC() {
  document.getElementById('ccVal').textContent = document.getElementById('fName').value.length;
}
function resetForm() {
  selPriority('medium');
  document.getElementById('fType').value = 'self';
  document.getElementById('fStore').value = 'all';
  document.getElementById('fName').value = '';
  document.getElementById('fAlarm').checked = true;
  updateCC();
  const d = new Date(); d.setHours(d.getHours()+24);
  document.getElementById('fDeadline').value = dtLocal(d);
}

function createTask() {
  const name = document.getElementById('fName').value.trim();
  const deadline = document.getElementById('fDeadline').value;
  if (!name) { toast('⚠️ Task name is required'); return; }
  if (!deadline) { toast('⚠️ Deadline is required'); return; }

  const t = {
    id: genId(), name, priority: selP,
    type: document.getElementById('fType').value,
    store: document.getElementById('fStore').value,
    deadline, alarm: document.getElementById('fAlarm').checked,
    status: 'pending', seen: false,
    createdAt: new Date().toISOString(),
    completedAt: null, cancelRemarks: null,
    rescheduled: false, rescheduleCount: 0, rescheduleHistory: []
  };
  tasks.unshift(t);
  save();
  scheduleAlarm(t);
  updateBadges();
  toast('✅ Task created!');
  switchTab('home');
}

// ───────────────────── ALARM ─────────────────────
function scheduleAlarm(task) {
  if (!task.alarm || task.status !== 'pending') return;
  const alarmMs = new Date(task.deadline).getTime() - 3600000;
  const delay = alarmMs - Date.now();
  if (delay > 0) {
    setTimeout(() => triggerAlarm(task.id), delay);
  } else if (delay > -3600000 && Date.now() < new Date(task.deadline).getTime()) {
    triggerAlarm(task.id);
  }
}

function triggerAlarm(id) {
  const t = tasks.find(x => x.id === id);
  if (!t || t.status !== 'pending') return;
  const area = document.getElementById('alarmArea');
  const el = document.createElement('div');
  el.className = 'alarm-card';
  el.innerHTML = `<span class="alarm-icon">⏰</span>
    <div class="alarm-text"><strong>DUE IN 1 HOUR</strong><br>${t.name.substring(0,60)}</div>
    <button class="alarm-close" onclick="this.parentElement.remove()">×</button>`;
  area.prepend(el);
  if ('Notification' in window && Notification.permission === 'granted') {
    new Notification('TaskOps ⏰', { body: `Due in 1 hour: ${t.name}` });
  }
}

// ───────────────────── HELPERS ─────────────────────
function dtLocal(d) {
  const pad = n => String(n).padStart(2,'0');
  return `${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())}T${pad(d.getHours())}:${pad(d.getMinutes())}`;
}

function fmtDt(str) {
  const d = new Date(str);
  return d.toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'2-digit'}) + ' ' +
    d.toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit',hour12:true});
}

function fmtStore(s) {
  return {all:'All Stores',kattur:'Kattur',cumbum:'Cumbum',mgt:'MGT',theni:'Theni',dindigul:'Dindigul'}[s]||s;
}
function fmtType(t) { return t==='high_command'?'🎯 High Cmd':'👤 Self'; }

function calcTAT(c, done) {
  const h = (new Date(done)-new Date(c))/3600000;
  return h < 24 ? Math.round(h)+'h' : (h/24).toFixed(1)+'d';
}

function dlInfo(deadline, status) {
  if (status==='completed'||status==='cancelled') return {label:'',cls:''};
  const diff = new Date(deadline)-Date.now();
  const h = diff/3600000;
  if (diff < 0) {
    const oh = Math.abs(h);
    return {label:`⚠️ Overdue ${oh<24?Math.round(oh)+'h':Math.round(oh/24)+'d'} ago`,cls:'overdue'};
  }
  if (h < 24) return {label:`🔥 Due in ${h<1?'<1h':Math.round(h)+'h'}`,cls:'due-soon'};
  return {label:`📅 ${fmtDt(deadline)}`,cls:''};
}

function isUrgent(task) {
  if (task.status !== 'pending') return false;
  const diff = new Date(task.deadline)-Date.now();
  return diff > 0 && diff < 86400000;
}

// ───────────────────── RENDER HOME ─────────────────────
function renderHome() {
  const total = tasks.length;
  const pending = tasks.filter(t=>t.status==='pending').length;
  const completed = tasks.filter(t=>t.status==='completed').length;
  const cancelled = tasks.filter(t=>t.status==='cancelled').length;

  document.getElementById('sTotal').textContent = total;
  document.getElementById('sPending').textContent = pending;
  document.getElementById('sDone').textContent = completed;

  drawPie(completed, pending, cancelled, total);
  const pct = (n,t) => t>0?Math.round(n/t*100):0;
  document.getElementById('lCompleted').textContent = `${completed} (${pct(completed,total)}%)`;
  document.getElementById('lPending').textContent = `${pending} (${pct(pending,total)}%)`;
  document.getElementById('lCancelled').textContent = `${cancelled} (${pct(cancelled,total)}%)`;

  const ago7 = new Date(Date.now()-604800000);
  const lately = tasks.filter(t=>t.status==='completed'&&t.completedAt&&new Date(t.completedAt)>ago7).length;
  document.getElementById('prodLately').textContent = lately;

  const doneWithTAT = tasks.filter(t=>t.status==='completed'&&t.completedAt&&t.createdAt);
  if (doneWithTAT.length > 0) {
    const avg = doneWithTAT.reduce((s,t)=>s+(new Date(t.completedAt)-new Date(t.createdAt)),0)/doneWithTAT.length;
    document.getElementById('prodTAT').textContent = (avg/86400000).toFixed(1)+'d';
  } else {
    document.getElementById('prodTAT').textContent = '—';
  }

  const p = pct(completed, total);
  document.getElementById('prodPct').textContent = p+'%';
  document.getElementById('prodBar').style.width = p+'%';

  const ongoing = tasks.filter(t=>t.status==='pending')
    .sort((a,b)=>new Date(a.deadline)-new Date(b.deadline))
    .slice(0,5);

  const c = document.getElementById('homeOngoing');
  c.innerHTML = ongoing.length === 0
    ? `<div class="empty-state"><div class="empty-icon">🎉</div><div class="empty-text">No pending tasks!</div></div>`
    : ongoing.map(t=>renderCard(t,true)).join('');

  updateBadges();
}

function drawPie(comp, pend, canc, total) {
  const cv = document.getElementById('pieChart');
  const ctx = cv.getContext('2d');
  const cx=50,cy=50,r=40,ir=24;
  ctx.clearRect(0,0,100,100);
  if (total===0) {
    ctx.beginPath(); ctx.arc(cx,cy,r,0,Math.PI*2); ctx.fillStyle='#1e2740'; ctx.fill();
    ctx.beginPath(); ctx.arc(cx,cy,ir,0,Math.PI*2); ctx.fillStyle='#0f1420'; ctx.fill();
    return;
  }
  const slices=[{v:comp,c:'#3dd68c'},{v:pend,c:'#ff7c3a'},{v:canc,c:'#6b7a90'}].filter(s=>s.v>0);
  let angle = -Math.PI/2;
  slices.forEach(s=>{
    const sweep = (s.v/total)*Math.PI*2;
    ctx.beginPath(); ctx.moveTo(cx,cy); ctx.arc(cx,cy,r,angle,angle+sweep); ctx.closePath();
    ctx.fillStyle=s.c; ctx.fill();
    angle+=sweep;
  });
  ctx.beginPath(); ctx.arc(cx,cy,ir,0,Math.PI*2); ctx.fillStyle='#0f1420'; ctx.fill();
  ctx.fillStyle='#dde4f0'; ctx.font='bold 11px Space Mono'; ctx.textAlign='center'; ctx.textBaseline='middle';
  ctx.fillText(Math.round(comp/total*100)+'%',cx,cy);
}

// ───────────────────── RENDER CARD ─────────────────────
function renderCard(task, compact=false) {
  const dl = dlInfo(task.deadline, task.status);
  const urg = isUrgent(task);

  let cls = 'task-card';
  if (task.rescheduled) cls += ' is-rescheduled';
  if (task.status==='cancelled') cls += ' is-cancelled';
  if (task.status==='completed') cls += ' is-completed';
  if (urg) cls += ' is-urgent';

  const seenBadge = !task.seen ? '<span class="tc-badge b-unseen">● NEW</span>' : '';
  const rBadge = task.rescheduleCount>0 ? `<span class="tc-badge b-resch">↺ ${task.rescheduleCount}x rescheduled</span>`:'';
  const cBadge = task.status==='cancelled'?'<span class="tc-badge b-cancelled">CANCELLED</span>':'';
  const doneBadge = task.status==='completed'?'<span class="tc-badge b-done">✓ DONE</span>':'';

  let actions = '';
  if (!compact) {
    if (task.status==='pending') {
      actions = `<div class="tc-actions">
        <button class="ta-btn ta-complete" onclick="event.stopPropagation();openComplete('${task.id}')">✓ Done</button>
        <button class="ta-btn ta-reschedule" onclick="event.stopPropagation();openReschedule('${task.id}')">↺ Resch.</button>
        <button class="ta-btn ta-cancel" onclick="event.stopPropagation();openCancel('${task.id}')">✕</button>
      </div>`;
    } else {
      actions = `<div class="tc-actions">
        <button class="ta-btn ta-reopen" onclick="event.stopPropagation();openReopen('${task.id}')">🔁 Reopen Task</button>
      </div>`;
    }
  }

  const tatHtml = task.completedAt
    ? `<div class="tc-tat">TAT: ${calcTAT(task.createdAt,task.completedAt)}</div>` : '';

  return `<div class="${cls}" data-p="${task.priority}" onclick="openDetail('${task.id}')">
    <div class="tc-header">
      <span class="tc-priority p-${task.priority}">${task.priority.toUpperCase()}</span>
      <span class="tc-name">${task.name}</span>
    </div>
    <div class="tc-badges">
      <span class="tc-badge b-store">📍${fmtStore(task.store)}</span>
      <span class="tc-badge b-type">${fmtType(task.type)}</span>
      ${seenBadge}${rBadge}${cBadge}${doneBadge}
    </div>
    <div class="tc-deadline ${dl.cls}">${dl.label||'📅 '+fmtDt(task.deadline)}</div>
    ${tatHtml}
    ${actions}
  </div>`;
}

// ───────────────────── RENDER TASKS ─────────────────────
function renderTasks() {
  let list = [...tasks];
  if (curFilter==='pending') list = list.filter(t=>t.status==='pending');
  else if (curFilter==='completed') list = list.filter(t=>t.status==='completed');
  else if (curFilter==='cancelled') list = list.filter(t=>t.status==='cancelled');
  else if (curFilter==='rescheduled') list = list.filter(t=>t.rescheduled);
  else if (curFilter==='urgent') list = list.filter(t=>t.priority==='urgent');

  const c = document.getElementById('tasksList');
  if (list.length===0) {
    c.innerHTML = `<div class="empty-state"><div class="empty-icon">📭</div><div class="empty-text">No tasks here</div></div>`;
    return;
  }

  const PORDER = ['urgent','high','medium','low'];
  const PCOLOR = {urgent:'var(--p-urgent)',high:'var(--p-high)',medium:'var(--p-med)',low:'var(--p-low)'};
  const PLABEL = {urgent:'🔴 URGENT!',high:'🟠 HIGH',medium:'🔵 MEDIUM',low:'🟢 LOW'};

  let html = '';
  PORDER.forEach(p => {
    const grp = list.filter(t=>t.priority===p)
      .sort((a,b)=>{
        if (a.status==='pending'&&b.status!=='pending') return -1;
        if (b.status==='pending'&&a.status!=='pending') return 1;
        return new Date(a.deadline)-new Date(b.deadline);
      });
    if (!grp.length) return;
    html += `<div class="priority-group">
      <div class="pg-header">
        <div class="pg-dot" style="background:${PCOLOR[p]}"></div>
        <div class="pg-label" style="color:${PCOLOR[p]}">${PLABEL[p]}</div>
        <div class="pg-count">${grp.length}</div>
      </div>
      ${grp.map(t=>renderCard(t,false)).join('')}
    </div>`;
  });
  c.innerHTML = html;
}

function setFilter(f, btn) {
  curFilter = f;
  document.querySelectorAll('.filter-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  renderTasks();
}

// ───────────────────── MODALS ─────────────────────
function openModal(id) { document.getElementById(id).classList.add('open'); }
function closeModal(id) { document.getElementById(id).classList.remove('open'); }
function overlayClose(e, id) { if (e.target.classList.contains('modal-overlay')) closeModal(id); }

function openComplete(id) { activeId=id; openModal('mComplete'); }
function confirmComplete() {
  const t = tasks.find(x=>x.id===activeId); if (!t) return;
  t.status='completed'; t.completedAt=new Date().toISOString();
  save(); closeModal('mComplete'); toast('✅ Task completed!'); renderTasks(); updateBadges();
  if (document.getElementById('tab-home').classList.contains('active')) renderHome();
}

function openReschedule(id) {
  activeId=id;
  document.getElementById('mNewDl').value='';
  document.getElementById('mReschRemarks').value='';
  openModal('mReschedule');
}
function confirmReschedule() {
  const t = tasks.find(x=>x.id===activeId); if (!t) return;
  const newDl = document.getElementById('mNewDl').value;
  const remarks = document.getElementById('mReschRemarks').value.trim();
  if (!newDl) { toast('⚠️ New deadline required'); return; }
  if (!remarks) { toast('⚠️ Remarks required'); return; }
  const oldDl = t.deadline;
  t.rescheduleHistory.push({oldDeadline:oldDl,newDeadline:newDl,remarks,at:new Date().toISOString()});
  t.deadline=newDl; t.rescheduled=true; t.rescheduleCount=(t.rescheduleCount||0)+1; t.status='pending';
  save(); closeModal('mReschedule'); toast('🔄 Task rescheduled!'); renderTasks();
}

function openCancel(id) {
  activeId=id; document.getElementById('mCancelReason').value=''; openModal('mCancel');
}
function confirmCancel() {
  const t = tasks.find(x=>x.id===activeId); if (!t) return;
  const r = document.getElementById('mCancelReason').value.trim();
  if (!r) { toast('⚠️ Reason required'); return; }
  t.status='cancelled'; t.cancelRemarks=r;
  save(); closeModal('mCancel'); toast('🚫 Task cancelled'); renderTasks(); updateBadges();
  if (document.getElementById('tab-home').classList.contains('active')) renderHome();
}

function openReopen(id) {
  activeId=id;
  document.getElementById('mReopenDl').value='';
  document.getElementById('mReopenRemarks').value='';
  const d=new Date(); d.setHours(d.getHours()+24);
  document.getElementById('mReopenDl').value=dtLocal(d);
  openModal('mReopen');
}
function confirmReopen() {
  const t = tasks.find(x=>x.id===activeId); if (!t) return;
  const newDl = document.getElementById('mReopenDl').value;
  if (!newDl) { toast('⚠️ New deadline required'); return; }
  const remarks = document.getElementById('mReopenRemarks').value.trim();
  const oldDl = t.deadline, oldStatus = t.status;
  t.deadline=newDl; t.status='pending'; t.completedAt=null; t.cancelRemarks=null;
  t.rescheduleHistory.push({oldDeadline:oldDl,newDeadline:newDl,remarks:remarks||`Reopened from ${oldStatus}`,at:new Date().toISOString()});
  t.rescheduled=true; t.rescheduleCount=(t.rescheduleCount||0)+1;
  save(); closeModal('mReopen'); toast('🔁 Task reopened!'); renderTasks(); updateBadges();
  if (document.getElementById('tab-home').classList.contains('active')) renderHome();
}

function openDetail(id) {
  const t = tasks.find(x=>x.id===id); if (!t) return;
  if (!t.seen) { t.seen=true; save(); updateBadges(); }

  const histHtml = t.rescheduleHistory.length>0 ? `
    <div style="margin-top:12px">
      <div class="form-label" style="margin-bottom:7px">Reschedule History</div>
      <div class="resch-history">
        ${t.rescheduleHistory.map((h,i)=>`
          <div class="rh-item">
            <span>#${i+1}: ${h.remarks.substring(0,40)}</span>
            <span style="color:var(--text3);flex-shrink:0">${fmtDt(h.newDeadline)}</span>
          </div>`).join('')}
      </div>
    </div>` : '';

  const statusColor = t.status==='completed'?'var(--p-low)':t.status==='cancelled'?'var(--text3)':'var(--p-high)';

  document.getElementById('detailContent').innerHTML = `
    <div>
      <div style="display:flex;align-items:flex-start;gap:8px;margin-bottom:12px">
        <span class="tc-priority p-${t.priority}" style="margin-top:2px">${t.priority.toUpperCase()}</span>
        <span style="font-size:14px;font-weight:700;line-height:1.35">${t.name}</span>
      </div>
      <div class="detail-grid">
        <div class="detail-cell"><div class="detail-cell-label">Store</div><div class="detail-cell-val">📍${fmtStore(t.store)}</div></div>
        <div class="detail-cell"><div class="detail-cell-label">Type</div><div class="detail-cell-val">${fmtType(t.type)}</div></div>
        <div class="detail-cell"><div class="detail-cell-label">Status</div><div class="detail-cell-val" style="color:${statusColor}">${t.status.toUpperCase()}</div></div>
        <div class="detail-cell"><div class="detail-cell-label">Deadline</div><div class="detail-cell-val" style="font-size:11px">${fmtDt(t.deadline)}</div></div>
        <div class="detail-cell"><div class="detail-cell-label">Created</div><div class="detail-cell-val" style="font-size:11px">${fmtDt(t.createdAt)}</div></div>
        ${t.completedAt?`<div class="detail-cell" style="border:1px solid rgba(61,214,140,.2)"><div class="detail-cell-label" style="color:var(--p-low)">Completed</div><div class="detail-cell-val" style="font-size:11px;color:var(--p-low)">${fmtDt(t.completedAt)}<br>TAT: ${calcTAT(t.createdAt,t.completedAt)}</div></div>`:''}
        ${t.cancelRemarks?`<div class="detail-cell" style="grid-column:1/-1"><div class="detail-cell-label">Cancel Reason</div><div class="detail-cell-val" style="font-size:12px;font-weight:400">${t.cancelRemarks}</div></div>`:''}
      </div>
      ${histHtml}
    </div>`;
  openModal('mDetail');
}

// ───────────────────── BADGES ─────────────────────
function markAllSeen() {
  let changed=false;
  tasks.forEach(t=>{ if (!t.seen){t.seen=true;changed=true;} });
  if (changed) save();
  updateBadges();
}

function updateBadges() {
  const unseen = tasks.filter(t=>!t.seen).length;
  const pill = document.getElementById('unseenPill');
  const dot = document.getElementById('navDot');
  pill.style.display = unseen>0?'inline-block':'none';
  pill.textContent = unseen+' NEW';
  dot.style.display = unseen>0?'block':'none';
}

// ───────────────────── TOAST ─────────────────────
let toastTimer;
function toast(msg) {
  const el = document.getElementById('toast');
  el.textContent = msg;
  el.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(()=>el.classList.remove('show'), 2600);
}

// ───────────────────── INIT ─────────────────────
function init() {
  if ('Notification' in window && Notification.permission==='default') Notification.requestPermission();
  const d=new Date(); d.setHours(d.getHours()+24);
  document.getElementById('fDeadline').value = dtLocal(d);
  tasks.filter(t=>t.alarm&&t.status==='pending').forEach(scheduleAlarm);
  renderHome();
  updateBadges();
  setInterval(()=>{
    if (document.getElementById('tab-home').classList.contains('active')) renderHome();
    else if (document.getElementById('tab-tasks').classList.contains('active')) renderTasks();
  }, 60000);
}

init();
</script>
</body>
</html>
