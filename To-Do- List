    <div class="modal-title">🔁 Reopen Task</div>
    <p style="color:var(--text2);font-size:13px;margin-bottom:14px">Set a new deadline to reopen this task as pending.</p>
    <div class="form-group">
      <label class="form-label">New Deadline <em>*</em></label>
      <input type="datetime-local" class="form-ctrl" id="mReopenDl">
